{
  "name": "syfom-desktop",
  "version": "0.4.10",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "description": "A desktop music player for Navidrome",
  "author": "qier222<qier222@outlook.com>",
  "scripts": {
    "serve": "vite --host 0.0.0.0",
    "build": "electron-vite build",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "typecheck": "vue-tsc --noEmit",
    "electron:build": "electron-vite build && electron-builder -p never",
    "electron:build-all": "electron-vite build && electron-builder -p never -mwl",
    "electron:build-mac": "electron-vite build && electron-builder -p never -m",
    "electron:build-win": "electron-vite build && electron-builder -p never -w",
    "electron:build-linux": "electron-vite build && electron-builder -p never -l",
    "electron:serve": "electron-vite dev",
    "electron:buildicon": "electron-icon-builder --input=./build/icons/icon.png --output=build --flatten",
    "electron:publish": "electron-vite build && electron-builder -mwl -p always",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "prettier": "prettier --write ./src"
  },
  "main": "out/main/background.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "axios": "^0.26.1",
    "@vscode/codicons": "^0.0.39",
    "change-case": "^4.1.2",
    "cli-color": "^2.0.0",
    "color": "^4.2.3",
    "crypto-js": "^4.0.0",
    "dayjs": "^1.8.36",
    "dexie": "^3.0.3",
    "electron-context-menu": "^3.1.2",
    "electron-debug": "^3.1.0",
    "electron-devtools-installer": "^3.2",
    "electron-icon-builder": "^2.0.1",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^4.3.0",
    "electron-store": "^8.0.1",
    "electron-updater": "^5.0.1",
    "express": "^4.17.1",
    "howler": "^2.2.3",
    "js-cookie": "^2.2.1",
    "jsbi": "^4.1.0",
    "lodash": "^4.17.20",
    "md5": "^2.3.0",
    "node-vibrant": "^3.2.1-alpha.1",
    "nprogress": "^0.2.0",
    "plyr": "^3.6.2",
    "register-service-worker": "^1.7.1",
    "tunnel": "^0.0.6",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.4",
    "vue-slider-component": "4.1.0-beta.7",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.34",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "prettier": "2.5.1",
    "sass": "^1.26.11",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^3.3.1"
  },
  "resolutions": {
    "icon-gen": "3.0.0",
    "degenerator": "2.2.0",
    "electron-builder": "^26.8.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true
    },
    "extends": [
      "plugin:vue/essential",
      "plugin:vue/recommended",
      "plugin:prettier/recommended",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "requireConfigFile": false
    },
    "globals": {
      "ipcRenderer": "off"
    },
    "rules": {
      "vue/multi-word-component-names": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
